      {h:'R',accent:true},{h:'R'},{h:'L'},{h:'L',accent:true},{h:'L'},{h:'R'},
      {h:'R',accent:true},{h:'R'},{h:'L'},{h:'L',accent:true},{h:'L'},{h:'R'},
    ], beats:4, subdivision:3,
  },
  {
    id: 36, name: 'Drag Paradiddle I', nameEn: 'Drag Paradiddle #1', cat: 'drag',
    desc: 'D eeD E D E E — drag no meio do paradiddle. Seis notas em sextina.',
    tips: ['D eeD E D E E', '6 notas em sextina', 'Drag no 2º tempo'],
    bpm: 70,
    pattern: [
      {h:'R'},{h:'r',grace:true},{h:'r',grace:true},{h:'R',accent:true},{h:'L'},{h:'R'},{h:'L'},{h:'L'},
      {h:'L'},{h:'l',grace:true},{h:'l',grace:true},{h:'L',accent:true},{h:'R'},{h:'L'},{h:'R'},{h:'R'},
    ], beats:4, subdivision:4,
  },
  {
    id: 37, name: 'Drag Paradiddle II', nameEn: 'Drag Paradiddle #2', cat: 'drag',
    desc: 'D eeD eeD E D E E — dois drags + paradiddle. Muito denso e complexo.',
    tips: ['Dois drags!', 'D eeD eeD E D E E', 'Começe muito lento'],
    bpm: 60,
    pattern: [
      {h:'R'},{h:'r',grace:true},{h:'r',grace:true},{h:'R'},{h:'l',grace:true},{h:'l',grace:true},{h:'L',accent:true},{h:'R'},{h:'L'},{h:'R'},{h:'R'},
      {h:'L'},{h:'l',grace:true},{h:'l',grace:true},{h:'L'},{h:'r',grace:true},{h:'r',grace:true},{h:'R',accent:true},{h:'L'},{h:'R'},{h:'L'},{h:'L'},
    ], beats:4, subdivision:4,
  },
  {
    id: 38, name: 'Ratamacue', nameEn: 'Single Ratamacue', cat: 'drag',
    desc: 'eeD E D E — drag + três singles em tercina. Muito usado em tambores de marcha.',
    tips: ['eeD E D E', 'Tercinas!', 'Marching classic'],
    bpm: 70,
    pattern: [
      {h:'r',grace:true},{h:'r',grace:true},{h:'R',accent:true},{h:'L'},{h:'R'},{h:'L'},
      {h:'l',grace:true},{h:'l',grace:true},{h:'L',accent:true},{h:'R'},{h:'L'},{h:'R'},
      {h:'r',grace:true},{h:'r',grace:true},{h:'R',accent:true},{h:'L'},{h:'R'},{h:'L'},
      {h:'l',grace:true},{h:'l',grace:true},{h:'L',accent:true},{h:'R'},{h:'L'},{h:'R'},
    ], beats:4, subdivision:6,
  },
  {
    id: 39, name: 'Ratamacue Duplo', nameEn: 'Double Ratamacue', cat: 'drag',
    desc: 'eeD eeD E D E — dois drags + três singles em tercina.',
    tips: ['Dois drags + 3 singles', 'eeD eeD E D E', 'Muita densidade'],
    bpm: 60,
    pattern: [
      {h:'r',grace:true},{h:'r',grace:true},{h:'R'},{h:'l',grace:true},{h:'l',grace:true},{h:'L',accent:true},{h:'R'},{h:'L'},{h:'R'},
      {h:'l',grace:true},{h:'l',grace:true},{h:'L'},{h:'r',grace:true},{h:'r',grace:true},{h:'R',accent:true},{h:'L'},{h:'R'},{h:'L'},
    ], beats:4, subdivision:4,
  },
  {
    id: 40, name: 'Ratamacue Triplo', nameEn: 'Triple Ratamacue', cat: 'drag',
    desc: 'eeD eeD eeD E D E — três drags + três singles. O mais denso dos ratamacues.',
    tips: ['Três drags!', 'eeD eeD eeD E D E', 'Começe MUITO lento'],
    bpm: 50,
    pattern: [
      {h:'r',grace:true},{h:'r',grace:true},{h:'R'},{h:'l',grace:true},{h:'l',grace:true},{h:'L'},{h:'r',grace:true},{h:'r',grace:true},{h:'R',accent:true},{h:'L'},{h:'R'},{h:'L'},
      {h:'l',grace:true},{h:'l',grace:true},{h:'L'},{h:'r',grace:true},{h:'r',grace:true},{h:'R'},{h:'l',grace:true},{h:'l',grace:true},{h:'L',accent:true},{h:'R'},{h:'L'},{h:'R'},
    ], beats:4, subdivision:4,
  },
];
const CATS = {
  roll:   { label: 'Rulos',   color: '#c0392b', tagCls: 'tag-roll' },
  diddle: { label: 'Diddles', color: '#1a5276', tagCls: 'tag-diddle' },
  flam:   { label: 'Flams',   color: '#1e8449', tagCls: 'tag-flam' },
  drag:   { label: 'Drags',   color: '#b7950b', tagCls: 'tag-drag' },
};


// ── AUDIO ENGINE ──────────────────────────────
// ── AUDIO ENGINE — Pure AudioContext synthesis (iOS precision) ────────────
// No HTML Audio elements. All sounds generated and scheduled directly via
// AudioContext, giving sample-accurate timing at any BPM on iOS Safari.

let audioCtx = null;

function getAC() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  return audioCtx;
}

function doUnlock(e) {
  if (e) { e.preventDefault(); e.stopPropagation(); }
  // Must create AudioContext synchronously inside user gesture on iOS
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  // Play a tiny silent buffer to fully unlock
  const buf = audioCtx.createBuffer(1, 1, audioCtx.sampleRate);
  const src = audioCtx.createBufferSource();
  src.buffer = buf; src.connect(audioCtx.destination); src.start(0);
  document.getElementById('audio-overlay').style.display = 'none';
}

// Synthesize a stick hit at a precise AudioContext time
// isRight: pitch difference R vs L
// isGrace: quiet, short
// isAccent: louder, higher pitch
function synthStick(ac, t, isRight, isGrace, isAccent) {
  const freq  = isRight ? (isAccent ? 520 : 380) : (isAccent ? 420 : 300);
  const vol   = isGrace ? 0.15 : isAccent ? 0.75 : 0.45;
  const decay = isGrace ? 0.04 : isAccent ? 0.10 : 0.07;

  // Oscillator (triangle = woodblock-like)
  const osc  = ac.createOscillator();
  const gain = ac.createGain();
  osc.type = 'triangle';
  osc.frequency.setValueAtTime(freq * 1.5, t);
  osc.frequency.exponentialRampToValueAtTime(freq, t + decay * 0.3);
  osc.connect(gain); gain.connect(ac.destination);
  gain.gain.setValueAtTime(vol, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + decay);
  osc.start(t); osc.stop(t + decay + 0.01);

  // Short noise burst for attack transient
  if (!isGrace) {
    const sr   = ac.sampleRate;
    const len  = Math.floor(sr * 0.018);
    const nbuf = ac.createBuffer(1, len, sr);
    const data = nbuf.getChannelData(0);
    for (let i = 0; i < len; i++) data[i] = (Math.random()*2-1) * (1 - i/len);
    const nsrc  = ac.createBufferSource();
    const ngain = ac.createGain();
    nsrc.buffer = nbuf;
    nsrc.connect(ngain); ngain.connect(ac.destination);
    ngain.gain.setValueAtTime(vol * 0.4, t);
    ngain.gain.exponentialRampToValueAtTime(0.001, t + 0.018);
    nsrc.start(t); nsrc.stop(t + 0.02);
  }
}

// Schedule a stick sound at AudioContext time t
function scheduleStick(t, isRight, isGrace, isAccent) {
  const ac = getAC();
  synthStick(ac, t, isRight, isGrace, isAccent);
}

// ── STATE ──────────────────────────────────────
let currentRudiment = null;
let bpm = 80;
let isPlaying = false;
// metronome uses Web Audio clock (see scheduler function)
let stepIdx = 0;
let beatIdx = 0;
let tapTimes = [];
let nonGraceIndices = [];

// ── SIDEBAR ───────────────────────────────────
function buildSidebar() {
  const list = document.getElementById('rudiment-list');
  list.innerHTML = '';
  const cats = ['roll','diddle','flam','drag'];
  cats.forEach(cat => {
    const items = RUDIMENTS.filter(r => r.cat === cat);
    const lbl = document.createElement('div');
    lbl.className = 'cat-label';
    lbl.textContent = CATS[cat].label;
    lbl.dataset.cat = cat;
    list.appendChild(lbl);
    items.forEach(r => {
      const el = document.createElement('div');
      el.className = 'rudiment-item';
      el.id = 'item-' + r.id;
      el.dataset.cat = cat;
      el.innerHTML = `<span class="item-num">${String(r.id).padStart(2,'0')}</span>
        <div class="item-name-wrap">
          <div class="item-name">${r.name}</div>
          ${r.nameEn && r.nameEn !== r.name ? `<div class="item-name-en">${r.nameEn}</div>` : ''}
        </div>`;
      el.onclick = () => selectRudiment(r);
      list.appendChild(el);
    });
  });
}

function buildWelcome() {
  const grid = document.getElementById('cat-cards');
  grid.innerHTML = '';
  ['roll','diddle','flam','drag'].forEach(cat => {
    const count = RUDIMENTS.filter(r => r.cat === cat).length;
    const card = document.createElement('div');
    card.className = 'cat-card';
    card.innerHTML = `<div class="cat-card-title" style="color:${CATS[cat].color}">${CATS[cat].label}</div>
      <div class="cat-card-count">${count} rudimentos</div>
      <div class="cat-bar" style="background:${CATS[cat].color}33;border:1px solid ${CATS[cat].color}44;"></div>`;
    card.onclick = () => selectRudiment(RUDIMENTS.find(r => r.cat === cat));
    grid.appendChild(card);
  });
}

function filterList(q) {
  const cat = document.getElementById('cat-filter')?.value || '';
  applyFilters(cat, q.toLowerCase());
}

function filterCat(cat) {
  const q = (document.getElementById('text-filter')?.value || '').toLowerCase();
  applyFilters(cat, q);
}

function applyFilters(cat, q) {
  document.querySelectorAll('.rudiment-item').forEach(el => {
    const name = el.querySelector('.item-name').textContent.toLowerCase();
    const nameEn = (el.querySelector('.item-name-en')?.textContent || '').toLowerCase();
    const matchText = !q || name.includes(q) || nameEn.includes(q);
    const itemCat = el.dataset.cat;
    const matchCat = !cat || itemCat === cat;
    el.style.display = (matchText && matchCat) ? '' : 'none';
  });
  document.querySelectorAll('.cat-label').forEach(el => {
    const labelCat = el.dataset.cat;
    if (cat && labelCat !== cat) { el.style.display = 'none'; return; }
    if (q) { el.style.display = 'none'; return; }
    el.style.display = '';
  });
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  if (window.innerWidth > 700) {
    document.getElementById('sidebar').classList.toggle('collapsed');
  }
}

// ── SELECT ────────────────────────────────────
function selectRudiment(r) {
  if (isPlaying) stopPlay();
  currentRudiment = r;

  // Sidebar highlight
  document.querySelectorAll('.rudiment-item').forEach(el => el.classList.remove('active'));
  const itemEl = document.getElementById('item-' + r.id);
  if (itemEl) { itemEl.classList.add('active'); itemEl.scrollIntoView({block:'nearest'}); }

  // Close sidebar on mobile
  if (window.innerWidth <= 700) {
    document.getElementById('sidebar').classList.remove('open');
  }

  // Topbar name
  document.getElementById('topbar-name').textContent =
    `#${String(r.id).padStart(2,'0')} — ${r.name}`;

  // Show rudiment view
  document.getElementById('welcome-box').style.display = 'none';
  const rv = document.getElementById('rudiment-view');
  rv.style.display = 'flex';

  // Info
  const info = document.getElementById('info-row');
  info.innerHTML = `<div class="info-desc">${r.desc}</div>
    <div class="info-tips">${r.tips.map(t =>
      `<div class="tip-row"><div class="tip-dot" style="background:${CATS[r.cat].color}"></div>${t}</div>`
    ).join('')}</div>`;

  renderNotation(r, -1);
  renderSpeedLadder();
  setBPM(r.bpm || 80);
}

// ── NOTATION ─────────────────────────────────
function renderNotation(r, playheadIdx) {
  const area = document.getElementById('notes-area');
  // Keep the label
  area.innerHTML = '<div class="staff-label">Baqueta</div>';

  const pattern = r.pattern;
  let nonGraceCount = 0;

  // Open repeat
  area.appendChild(makeRep('open'));

  pattern.forEach((note, i) => {
    const hand = note.h.toUpperCase();
    const isGrace = note.grace || note.h !== note.h.toUpperCase();

    // Beat separator
    if (!isGrace) {
      if (nonGraceCount > 0 && nonGraceCount % r.subdivision === 0) {
        const sep = document.createElement('div');
        sep.className = 'beat-sep';
        area.appendChild(sep);
      }
    }

    const cell = document.createElement('div');
    cell.className = 'ncell' + (isGrace ? ' is-grace' : '');

    if (!isGrace && nonGraceCount === playheadIdx) {
      cell.classList.add('playhead');
    }

    // Stem
    const stem = document.createElement('div');
    stem.className = 'note-stem col-' + (isGrace ? 'g' : hand);
    if (isGrace) stem.style.background = '#aaa';
    cell.appendChild(stem);

    // Body
    const body = document.createElement('div');
    body.className = 'note-body';
    if (note.buzz) {
      body.classList.add('col-' + hand, 'buzz');
      body.style.background = 'transparent';
    } else if (isGrace) {
      body.style.background = '#999';
      body.style.borderColor = '#999';
    } else {
      body.classList.add('col-' + hand);
    }
    if (note.accent) {
      const acc = document.createElement('div');
      acc.className = 'accent-mark';
      acc.textContent = '>';
      acc.style.color = hand === 'R' ? 'var(--R)' : 'var(--L)';
      cell.appendChild(acc);
    }
    cell.appendChild(body);

    // Hand label
    const lbl = document.createElement('div');
    lbl.className = 'hand-lbl col-' + (isGrace ? 'g' : hand);
    lbl.textContent = note.h;
    if (isGrace) { lbl.style.fontSize = '0.55rem'; lbl.style.color = '#aaa'; }
    cell.appendChild(lbl);

    area.appendChild(cell);
    if (!isGrace) nonGraceCount++;
  });

  area.appendChild(makeRep('close'));
}

function makeRep(type) {
  const el = document.createElement('div');
  el.className = 'rep';
  if (type === 'open') {
    const dots = document.createElement('div');
    dots.className = 'rep-dots';
    dots.innerHTML = '<div class="rep-dot"></div><div class="rep-dot"></div>';
    el.appendChild(document.createElement('div')).className = 'rep-thin';
    const thick = document.createElement('div'); thick.className = 'rep-thick';
    el.insertBefore(dots, el.firstChild);
    el.appendChild(thick);
  } else {
    const thick = document.createElement('div'); thick.className = 'rep-thick';
    const thin = document.createElement('div'); thin.className = 'rep-thin';
    const dots = document.createElement('div');
    dots.className = 'rep-dots';
    dots.innerHTML = '<div class="rep-dot"></div><div class="rep-dot"></div>';
    el.appendChild(thick); el.appendChild(thin); el.appendChild(dots);
  }
  return el;
}

// ── SPEED LADDER ─────────────────────────────
const SPEEDS = [40,50,60,70,80,90,100,110,120,140,160,180,200,240];

function renderSpeedLadder() {
  const el = document.getElementById('speed-ladder');
  el.innerHTML = '';
  SPEEDS.forEach(s => {
    const btn = document.createElement('div');
    btn.className = 'speed-step' + (s === bpm ? ' current' : '');
    btn.id = 'ss-' + s;
    btn.textContent = s;
    btn.onclick = () => setBPM(s);
    el.appendChild(btn);
  });
}

function updateSpeedLadder() {
  document.querySelectorAll('.speed-step').forEach(el => {
    el.classList.remove('current');
    if (parseInt(el.textContent) === bpm) el.classList.add('current');
  });
}

// ── METRONOME ────────────────────────────────
function buildNonGrace(pattern) {
  nonGraceIndices = pattern.map((n,i) => n.grace ? null : i).filter(i => i !== null);
}

// ── WEB AUDIO CLOCK SCHEDULER ────────────────
// Uses AudioContext.currentTime as the clock source — immune to setTimeout/setInterval
// drift on iOS Safari. Schedules audio slightly ahead, updates visuals via requestAnimationFrame.

let nextNoteTime = 0;       // when the next note should sound (AudioContext time)
let scheduleAheadTime = 0.2; // seconds to look ahead (larger = more stable at high BPM)
let lookahead = 20;          // ms between scheduler calls
let schedulerTimer = null;
let visualQueue = [];        // notes scheduled but not yet shown visually

function scheduleNote(time, noteIndex, isGrace, isRight, isAccent) {
  // Schedule sound at exact AudioContext time — no setTimeout, sample-accurate
  scheduleStick(time, isRight, isGrace, isAccent);
  // Queue for visual update
  visualQueue.push({ time, stepVisual: noteIndex });
}

function scheduler() {
  if (!isPlaying || !currentRudiment) return;
  const ctx = getAC();

  while (nextNoteTime < ctx.currentTime + scheduleAheadTime) {
    const totalSteps = nonGraceIndices.length;
    const noteIdx = nonGraceIndices[stepIdx % totalSteps];
    const note = currentRudiment.pattern[noteIdx];
    const hand = note.h.toUpperCase();

    // Schedule grace note slightly before main note
    if (noteIdx > 0) {
      const prev = currentRudiment.pattern[noteIdx - 1];
      if (prev && prev.grace) {
        scheduleNote(nextNoteTime - 0.03, stepIdx % totalSteps, true, prev.h.toUpperCase() === 'R', false);
      }
    }

    // Schedule main note
    scheduleNote(nextNoteTime, stepIdx % totalSteps, false, hand === 'R', !!note.accent);

    // Beat pip index
    const beatPipIdx = beatIdx % 4;
    visualQueue.push({ time: nextNoteTime, beatPip: beatPipIdx, stepVisual: stepIdx % totalSteps });

    nextNoteTime += 60.0 / bpm;
    stepIdx++;
    beatIdx++;
  }

  schedulerTimer = setTimeout(scheduler, lookahead);
}

function drawVisuals() {
  if (!isPlaying) return;
  requestAnimationFrame(drawVisuals);

  const ctx = getAC();
  const now = ctx.currentTime;

  while (visualQueue.length > 0 && visualQueue[0].time <= now + 0.01) {
    const item = visualQueue.shift();
    if (item.beatPip !== undefined) {
      document.querySelectorAll('.beat-pip').forEach((p, i) => {
        p.classList.remove('on', 'on-accent');
        if (i === item.beatPip) p.classList.add(item.beatPip === 0 ? 'on-accent' : 'on');
      });
    }
    if (item.stepVisual !== undefined && currentRudiment) {
      renderNotation(currentRudiment, item.stepVisual);
    }
  }
}

function startPlay() {
  if (!currentRudiment) return;
  buildNonGrace(currentRudiment.pattern);
  isPlaying = true;
  stepIdx = 0;
  beatIdx = 0;
  visualQueue = [];

  const ctx = getAC();
  nextNoteTime = ctx.currentTime + 0.1; // startup delay

  scheduler();
  requestAnimationFrame(drawVisuals);

  const btn = document.getElementById('play-btn');
  btn.textContent = '⏹ Stop'; btn.classList.add('running');
}

function stopPlay() {
  isPlaying = false;
  clearTimeout(schedulerTimer);
  visualQueue = [];
  document.querySelectorAll('.beat-pip').forEach(p => p.classList.remove('on', 'on-accent'));
  if (currentRudiment) renderNotation(currentRudiment, -1);
  const btn = document.getElementById('play-btn');
  btn.textContent = '▶ Play'; btn.classList.remove('running');
}

function togglePlay() {
  if (!currentRudiment) return;
  if (isPlaying) stopPlay(); else startPlay();
}

// ── BPM ──────────────────────────────────────
function setBPM(v) {
  bpm = Math.max(30, Math.min(300, parseInt(v)));
  document.getElementById('bpm-display').textContent = bpm;
  document.getElementById('bpm-slider').value = bpm;
  updateSpeedLadder();
  if (isPlaying) { stopPlay(); startPlay(); }
}
function adjBPM(d) { setBPM(bpm + d); }
function tapTempo() {
  const now = Date.now();
  tapTimes.push(now);
  if (tapTimes.length > 6) tapTimes.shift();
  if (tapTimes.length >= 2) {
    const diffs = tapTimes.slice(1).map((t,i) => t - tapTimes[i]);
    setBPM(Math.round(60000 / (diffs.reduce((a,b) => a+b,0) / diffs.length)));
  }
}

// ── NAVIGATION ───────────────────────────────
function navigateRudiment(dir) {
  const idx = currentRudiment ? RUDIMENTS.findIndex(r => r.id === currentRudiment.id) : -1;
  const next = RUDIMENTS[idx + dir];
  if (next) selectRudiment(next);
  else if (!currentRudiment) selectRudiment(RUDIMENTS[0]);
}

// ── KEYBOARD ─────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT') return;
  if (e.key === ' ') { e.preventDefault(); togglePlay(); }
  if (e.key === 'ArrowRight') navigateRudiment(1);
  if (e.key === 'ArrowLeft') navigateRudiment(-1);
  if (e.key === 'ArrowUp') adjBPM(5);
  if (e.key === 'ArrowDown') adjBPM(-5);
});

// ── INIT ─────────────────────────────────────
buildSidebar();
buildWelcome();
setBPM(80);
</script>
</body>
</html>
